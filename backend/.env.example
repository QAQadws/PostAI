APP_NAME=PostAI Backend
APP_VERSION=0.1.0
CORS_ORIGINS=*
ASSET_DIR=generated
ASSET_URL_PATH=/assets

# If true, remote model failures fall back to local rule/heuristic agents.
# If false, configured model failures stop the graph and return an error event.
ALLOW_MODEL_FALLBACK=false

# Text LLM for ContentExtractor, StyleDirector, and SpatialLayoutPlanner.
# Leave these blank to use local deterministic fallback agents.
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_RESPONSE_FORMAT=json_object

# Vision model for VLMCritic.
# Leave these blank to use the heuristic critic.
VISION_API_KEY=
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen3-vl-flash

# DashScope image generation model for IllustrationAgent.
# Leave blank to skip generated illustrations and keep the poster pipeline working.
IMAGE_API_KEY=
IMAGE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
IMAGE_MODEL=qwen-image-2.0
IMAGE_SIZE=1024x1024
IMAGE_TIMEOUT_SECONDS=120
